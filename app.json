{
  "expo": {
    "name": "Smart Health",
    "slug": "smart-healty",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "versionCode": 3,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.smarthealthy.smarthealty"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/smart-health-splash.png",
          "imageWidth": 393,
          "resizeMode": "contain",
          "backgroundColor": "#F8FAFF",
          "dark": {
            "backgroundColor": "#F8FAFF"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#126E82",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Smart Health to use your location for nearby hospitals and SOS messages."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Smart Health to access a photo you choose to share with the health assistant.",
          "cameraPermission": "Allow Smart Health to photograph an injury for a first aid assessment.",
          "microphonePermission": false
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Smart Health to use your microphone for voice chat.",
          "speechRecognitionPermission": "Allow Smart Health to convert your speech into text."
        }
      ],
      "expo-secure-store",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Smart Health to use your microphone for voice chat.",
          "recordAudioAndroid": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "69ea2e72-12c7-4c50-b60e-01d7cdafb328"
      }
    },
    "owner": "smart-healthy"
  }
}
